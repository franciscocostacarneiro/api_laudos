{
  "openapi": "3.1.0",
  "info": {
    "title": "API Laudos de Avaliação de Imóveis (CEF)",
    "description": "REST API for querying real estate valuation reports (laudos) extracted from Caixa Econômica Federal (SIMIL) PDFs for the Região Metropolitana de Belo Horizonte (MG), Brazil.",
    "contact": {
      "name": "Francisco Costa Carneiro",
      "url": "https://www.gov.br/caixa"
    },
    "license": {
      "name": "Restricted — CEF internal data",
      "url": "https://www.gov.br/caixa"
    },
    "version": "1.0.0"
  },
  "paths": {
    "/health": {
      "get": {
        "tags": [
          "Health"
        ],
        "summary": "Health check",
        "description": "Returns service health, current version and number of loaded reports.",
        "operationId": "health_health_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/info": {
      "get": {
        "tags": [
          "Health"
        ],
        "summary": "Dataset and API metadata",
        "description": "Returns metadata about the API and the underlying dataset.",
        "operationId": "info_info_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/InfoResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/laudos": {
      "get": {
        "tags": [
          "Laudos"
        ],
        "summary": "List valuation reports (laudos)",
        "description": "Returns a paginated list of real estate valuation reports (laudos). Supports filtering by category, location, value and area ranges, reference date, and free-text search. Sort by any whitelisted field.",
        "operationId": "list_laudos_api_v1_laudos_get",
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 1,
              "description": "Page number (1-indexed).",
              "default": 1,
              "title": "Page"
            },
            "description": "Page number (1-indexed)."
          },
          {
            "name": "pageSize",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "maximum": 100,
              "minimum": 1,
              "description": "Items per page (1-100).",
              "default": 20,
              "title": "Pagesize"
            },
            "description": "Items per page (1-100)."
          },
          {
            "name": "sortBy",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "description": "Sort field. One of: areaAvaliacaoM2, bairro, dataReferenciaAvaliacao, id, municipio, numeroLaudo, valorAvaliacaoReais",
              "default": "id",
              "title": "Sortby"
            },
            "description": "Sort field. One of: areaAvaliacaoM2, bairro, dataReferenciaAvaliacao, id, municipio, numeroLaudo, valorAvaliacaoReais"
          },
          {
            "name": "sortOrder",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "description": "Sort order: 'asc' or 'desc'.",
              "default": "asc",
              "title": "Sortorder"
            },
            "description": "Sort order: 'asc' or 'desc'."
          },
          {
            "name": "categoria",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Property category: 'Apartamento', 'Casa' or 'Lote'.",
              "title": "Categoria"
            },
            "description": "Property category: 'Apartamento', 'Casa' or 'Lote'."
          },
          {
            "name": "uf",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Federation unit (state), e.g. 'MG'.",
              "title": "Uf"
            },
            "description": "Federation unit (state), e.g. 'MG'."
          },
          {
            "name": "municipio",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Municipality name (case-insensitive).",
              "title": "Municipio"
            },
            "description": "Municipality name (case-insensitive)."
          },
          {
            "name": "bairro",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Neighborhood name (case-insensitive).",
              "title": "Bairro"
            },
            "description": "Neighborhood name (case-insensitive)."
          },
          {
            "name": "grupoLaudo",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Report group: 'Unidade em Prédio', 'Unidade Isolada Construção' or 'Unidade Isolada Terreno'.",
              "title": "Grupolaudo"
            },
            "description": "Report group: 'Unidade em Prédio', 'Unidade Isolada Construção' or 'Unidade Isolada Terreno'."
          },
          {
            "name": "valorMin",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "number",
                  "minimum": 0
                },
                {
                  "type": "null"
                }
              ],
              "description": "Minimum appraisal value in BRL.",
              "title": "Valormin"
            },
            "description": "Minimum appraisal value in BRL."
          },
          {
            "name": "valorMax",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "number",
                  "minimum": 0
                },
                {
                  "type": "null"
                }
              ],
              "description": "Maximum appraisal value in BRL.",
              "title": "Valormax"
            },
            "description": "Maximum appraisal value in BRL."
          },
          {
            "name": "areaMin",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "number",
                  "minimum": 0
                },
                {
                  "type": "null"
                }
              ],
              "description": "Minimum evaluation area in m².",
              "title": "Areamin"
            },
            "description": "Minimum evaluation area in m²."
          },
          {
            "name": "areaMax",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "number",
                  "minimum": 0
                },
                {
                  "type": "null"
                }
              ],
              "description": "Maximum evaluation area in m².",
              "title": "Areamax"
            },
            "description": "Maximum evaluation area in m²."
          },
          {
            "name": "dataInicio",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Reference date lower bound (DD/MM/YYYY).",
              "title": "Datainicio"
            },
            "description": "Reference date lower bound (DD/MM/YYYY)."
          },
          {
            "name": "dataFim",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Reference date upper bound (DD/MM/YYYY).",
              "title": "Datafim"
            },
            "description": "Reference date upper bound (DD/MM/YYYY)."
          },
          {
            "name": "q",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Free-text search across numero, bairro, endereco and municipio.",
              "title": "Q"
            },
            "description": "Free-text search across numero, bairro, endereco and municipio."
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaginatedLaudos"
                }
              }
            }
          },
          "422": {
            "description": "Validation error for query parameters."
          }
        }
      }
    },
    "/api/v1/laudos/stats": {
      "get": {
        "tags": [
          "Laudos"
        ],
        "summary": "Aggregate statistics over the dataset",
        "description": "Returns aggregate statistics: counts and value averages by category and municipality, plus min/max/mean/median for unit value (R$/m²) and total appraisal value (R$).",
        "operationId": "get_stats_api_v1_laudos_stats_get",
        "parameters": [
          {
            "name": "categoria",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Filter stats by property category.",
              "title": "Categoria"
            },
            "description": "Filter stats by property category."
          },
          {
            "name": "municipio",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Filter stats by municipality.",
              "title": "Municipio"
            },
            "description": "Filter stats by municipality."
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StatsResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/laudos/{laudoId}": {
      "get": {
        "tags": [
          "Laudos"
        ],
        "summary": "Get a single valuation report by ID",
        "description": "Returns the full representation of a single laudo by its internal sequential ID.",
        "operationId": "get_laudo_api_v1_laudos__laudoId__get",
        "parameters": [
          {
            "name": "laudoId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "title": "Laudoid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Laudo"
                }
              }
            }
          },
          "404": {
            "description": "No laudo with the given ID exists."
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    }
  },
