{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "nixpacks"
  },
  "deploy": {
    "startCommand": "gunicorn --bind 0.0.0.0:8000 --workers 4 --worker-class uvicorn.workers.UvicornWorker --timeout 120 app.main:app",
    "restartPolicyMaxRetries": 5,
    "restartPolicyWindowMs": 60000
  },
  "env": {
    "PYTHONUNBUFFERED": "1",
    "PORT": "8000"
  }
}
